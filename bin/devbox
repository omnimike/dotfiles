#!/bin/bash
set -euo pipefail

DIR="$(cd "$(dirname "$0")"; pwd -P)/.."
IMAGE=devbox
TAG=latest
CONTAINER=devbox

do_build() {
  podman build \
    -f "$DIR/devbox/Containerfile" \
    -t "$IMAGE:$TAG" \
    --rm \
    --no-cache \
    "$DIR"
  podman image prune -f
}

do_run() {
  if ! podman image exists "$IMAGE:$TAG" 2>/dev/null; then
    do_build
  fi
  local host=`basename "$PWD" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g'`
  podman run -it \
    --rm \
    --name "$CONTAINER" \
    -e TZ=$(cat /etc/timezone) \
    --replace \
    --network host \
    --hostname "$host-devbox" \
    --volume "$PWD:/home/devbox/ws" \
    --workdir /home/devbox/ws \
    --userns=keep-id \
    "$IMAGE:$TAG"
}

do_clean() {
  podman rm -f "$CONTAINER" 2>/dev/null || true
  podman rmi "$IMAGE:$TAG" 2>/dev/null || true
}

case "${1:-}" in
  build) do_build ;;
  run|"")   do_run ;;
  clean) do_clean ;;
esac
